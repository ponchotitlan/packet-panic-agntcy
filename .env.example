# --- Proveedor de LLM (vía LiteLLM) ---
# Ejemplos: "openai/gpt-4o-mini", "azure/<deployment>", "groq/<modelo>"
LLM_MODEL="openai/gpt-4o-mini"
OPENAI_API_KEY=

# --- Transporte de mensajería A2A ---
# Opciones: SLIM (por defecto), NATS, A2A (HTTP nativo, sin gateway)
DEFAULT_MESSAGE_TRANSPORT=SLIM
TRANSPORT_SERVER_ENDPOINT=http://localhost:46357

# --- Agente Detector (servidor A2A) ---
DETECTOR_AGENT_HOST=localhost
DETECTOR_AGENT_PORT=9999

# --- Agente Supervisor (API HTTP) ---
SUPERVISOR_HOST=0.0.0.0
SUPERVISOR_PORT=8000

# --- Tiempos de espera ---
A2A_REQUEST_TIMEOUT=60

# --- Observabilidad ---
OTLP_HTTP_ENDPOINT=http://localhost:4318
OTEL_SDK_DISABLED=true

# --- Logs ---
LOGGING_LEVEL=INFO
