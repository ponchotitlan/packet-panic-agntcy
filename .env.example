# --- Proveedor de LLM (vía LiteLLM) ---
# Ejemplos: "openai/gpt-4o-mini", "azure/<deployment>", "groq/<modelo>"
LLM_MODEL="openai/gpt-4o-mini"
OPENAI_API_KEY=

# --- Servidor MCP de pyATS ---
# Cuando está habilitado, el Detector usa pyATS para consultas reales a la red.
PYATS_MCP_ENABLED=true
PYATS_MCP_TRANSPORT=http
PYATS_MCP_HOST=0.0.0.0
PYATS_MCP_PORT=8082
PYATS_MCP_KEEP_ARTIFACTS=1
# URL que el Detector usa para alcanzar el MCP. En Docker Compose el host es el
# nombre del servicio (`pyats-mcp`); en local suele ser http://localhost:8082/mcp.
PYATS_MCP_URL=http://pyats-mcp:8082/mcp

# --- Transporte de mensajería A2A ---
# Opciones: SLIM (por defecto), NATS, A2A (HTTP nativo, sin gateway)
DEFAULT_MESSAGE_TRANSPORT=SLIM
TRANSPORT_SERVER_ENDPOINT=http://localhost:46357

# --- Agente Detector (servidor A2A) ---
DETECTOR_AGENT_HOST=localhost
DETECTOR_AGENT_PORT=9999

# --- Agente Supervisor (API HTTP) ---
SUPERVISOR_HOST=0.0.0.0
SUPERVISOR_PORT=8000

# --- Tiempos de espera ---
# Segundos que el supervisor espera la respuesta del detector. El ciclo ReAct
# del detector (LLM + herramientas pyATS/MCP) puede tardar; súbelo si recibes
# timeouts (HTTP 504) en consultas que demoran más de lo habitual.
A2A_REQUEST_TIMEOUT=180

# --- Observabilidad ---
# Colector OTLP/HTTP que recibe las trazas (Observe SDK / OpenTelemetry).
# En local apunta a Jaeger (http://localhost:4318). En Docker Compose el
# endpoint se sobreescribe a http://jaeger:4318 desde docker-compose.yaml.
OTLP_HTTP_ENDPOINT=http://localhost:4318
# Pon OTEL_SDK_DISABLED=false para exportar trazas al colector. La UI de
# Jaeger queda disponible en http://localhost:16686.
OTEL_SDK_DISABLED=true
# Jaeger solo ingiere trazas. Deja el export de métricas OTLP desactivado
# (no expone /v1/metrics) para evitar errores 404 en los logs. Ponlo a true
# solo si apuntas a un colector OTEL completo.
OBSERVE_METRICS_ENABLED=false

# --- Logs ---
LOGGING_LEVEL=INFO
